@model Usuario
<div class="card"><div class="card-header"><h1>Detalle de usuario</h1></div><div class="card-body"><div class="user-detail-layout"><div>@if (!string.IsNullOrWhiteSpace(Model.StrRutaImagen)){<img src="@Model.StrRutaImagen" alt="Imagen usuario" class="user-preview" />}else{<div class="image-placeholder">Sin imagen</div>}</div><div class="definition-list"><div><strong>ID:</strong> @Model.Id</div><div><strong>Usuario:</strong> @Model.StrNombreUsuario</div><div><strong>Perfil:</strong> @Model.Perfil?.StrNombrePerfil</div><div><strong>Correo:</strong> @Model.StrCorreo</div><div><strong>Celular:</strong> @Model.StrNumeroCelular</div><div><strong>Estado:</strong> @Model.EstadoTexto</div></div></div><div class="page-actions"><a asp-action="Edit" asp-route-id="@Model.Id" class="btn">Editar</a><a asp-action="Index" class="btn btn-outline">Regresar</a></div></div></div>
