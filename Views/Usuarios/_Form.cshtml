@model UsuarioFormViewModel
<div class="form-grid"><div class="form-group"><label asp-for="StrNombreUsuario"></label><input asp-for="StrNombreUsuario" class="form-control" autocomplete="off" /><span asp-validation-for="StrNombreUsuario" class="field-validation"></span></div><div class="form-group"><label asp-for="IdPerfil"></label><select asp-for="IdPerfil" asp-items="Model.Perfiles" class="form-control"><option value="">Selecciona un perfil</option></select><span asp-validation-for="IdPerfil" class="field-validation"></span></div><div class="form-group"><label asp-for="StrPwd"></label><input asp-for="StrPwd" class="form-control" autocomplete="new-password" /><span asp-validation-for="StrPwd" class="field-validation"></span></div><div class="form-group"><label asp-for="ConfirmarPwd"></label><input asp-for="ConfirmarPwd" class="form-control" autocomplete="new-password" /><span asp-validation-for="ConfirmarPwd" class="field-validation"></span></div><div class="form-group"><label asp-for="StrCorreo"></label><input asp-for="StrCorreo" class="form-control" /><span asp-validation-for="StrCorreo" class="field-validation"></span></div><div class="form-group"><label asp-for="StrNumeroCelular"></label><input asp-for="StrNumeroCelular" class="form-control" maxlength="10" /><span asp-validation-for="StrNumeroCelular" class="field-validation"></span></div><div class="form-group"><label asp-for="IdEstadoUsuario"></label><select asp-for="IdEstadoUsuario" class="form-control"><option value="1">Activo</option><option value="2">Inactivo</option></select><span asp-validation-for="IdEstadoUsuario" class="field-validation"></span></div><div class="form-group"><label asp-for="ImagenArchivo"></label><input asp-for="ImagenArchivo" class="form-control" type="file" accept=".jpg,.jpeg,.png,.webp" id="imagen-usuario-input" /><span asp-validation-for="ImagenArchivo" class="field-validation"></span><small class="form-help">Máximo 2 MB. Formatos permitidos: JPG, JPEG, PNG, WEBP.</small></div></div>
@if (!string.IsNullOrWhiteSpace(Model.ImagenActual))
{<div class="image-preview-wrapper" id="imagen-usuario-preview-wrapper"><p><strong>Imagen actual:</strong></p><img src="@Model.ImagenActual" alt="Imagen actual" class="user-preview" id="imagen-usuario-preview" /></div>}
else
{<div class="image-preview-wrapper hidden" id="imagen-usuario-preview-wrapper"><p><strong>Vista previa:</strong></p><img src="" alt="Vista previa" class="user-preview" id="imagen-usuario-preview" /></div>}
