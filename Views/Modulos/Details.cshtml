@model Modulo
<div class="card card-narrow"><div class="card-header"><h1>Detalle de módulo</h1></div><div class="card-body"><div class="definition-list"><div><strong>ID:</strong> @Model.Id</div><div><strong>Nombre:</strong> @Model.StrNombreModulo</div><div><strong>Clave:</strong> @Model.StrClave</div><div><strong>Controlador:</strong> @Model.StrControlador</div><div><strong>Estático:</strong> @(Model.BitEstatico ? "Sí" : "No")</div></div><div class="page-actions"><a asp-action="Edit" asp-route-id="@Model.Id" class="btn">Editar</a><a asp-action="Index" class="btn btn-outline">Regresar</a></div></div></div>
