@model PermisoPerfil
<div class="form-grid"><div class="form-group"><label asp-for="IdPerfil"></label><select asp-for="IdPerfil" asp-items="ViewBag.Perfiles" class="form-control"><option value="">Selecciona un perfil</option></select><span asp-validation-for="IdPerfil" class="field-validation"></span></div><div class="form-group"><label asp-for="IdModulo"></label><select asp-for="IdModulo" asp-items="ViewBag.Modulos" class="form-control"><option value="">Selecciona un módulo</option></select><span asp-validation-for="IdModulo" class="field-validation"></span></div></div><div class="permissions-grid"><label class="checkbox-label"><input asp-for="BitAgregar" /> Agregar</label><label class="checkbox-label"><input asp-for="BitEditar" /> Editar</label><label class="checkbox-label"><input asp-for="BitConsulta" /> Consultar</label><label class="checkbox-label"><input asp-for="BitEliminar" /> Eliminar</label><label class="checkbox-label"><input asp-for="BitDetalle" /> Detalle</label></div>
