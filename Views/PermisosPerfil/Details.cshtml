@model PermisoPerfil
<div class="card card-narrow"><div class="card-header"><h1>Detalle de permiso</h1></div><div class="card-body"><div class="definition-list"><div><strong>ID:</strong> @Model.Id</div><div><strong>Perfil:</strong> @Model.Perfil?.StrNombrePerfil</div><div><strong>Módulo:</strong> @Model.Modulo?.StrNombreModulo</div><div><strong>Agregar:</strong> @(Model.BitAgregar ? "Sí" : "No")</div><div><strong>Editar:</strong> @(Model.BitEditar ? "Sí" : "No")</div><div><strong>Consultar:</strong> @(Model.BitConsulta ? "Sí" : "No")</div><div><strong>Eliminar:</strong> @(Model.BitEliminar ? "Sí" : "No")</div><div><strong>Detalle:</strong> @(Model.BitDetalle ? "Sí" : "No")</div></div><div class="page-actions"><a asp-action="Edit" asp-route-id="@Model.Id" class="btn">Editar</a><a asp-action="Index" class="btn btn-outline">Regresar</a></div></div></div>
