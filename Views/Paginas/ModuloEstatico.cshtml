@model PaginaEstaticaViewModel
<div class="page-header">
    <div>
        <h1>@Model.Titulo</h1>
        //<p>Esta es una pantalla estática. Los botones CRUD se muestran según los permisos del perfil, pero no tienen funcionalidad a base de datos.</p>
    </div>
</div>
<div class="card">
    <div class="card-body">
        <div class="page-actions">
            <button class="btn" type="button" disabled="@(Model.PuedeAgregar ? null : "disabled")">Agregar</button>
            <button class="btn" type="button" disabled="@(Model.PuedeEditar ? null : "disabled")">Editar</button>
            <button class="btn" type="button" disabled="@(Model.PuedeConsultar ? null : "disabled")">Consultar</button>
            <button class="btn" type="button" disabled="@(Model.PuedeEliminar ? null : "disabled")">Eliminar</button>
            <button class="btn" type="button" disabled="@(Model.PuedeDetalle ? null : "disabled")">Detalle</button>
        </div>
        <div class="static-screen-note">
           // <p>Clave de módulo: <strong>@Model.ClaveModulo</strong></p>
            //<p>Esta vista es responsiva y no depende de JavaScript para mostrarse.</p>
        </div>
    </div>
</div>
