@model PaginaEstaticaViewModel

<div class="page-header">
    <div>
        <h1>@Model.Titulo</h1>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="page-actions">
            @if (Model.PuedeAgregar)
            {
                <button class="btn" type="button">Agregar</button>
            }

            @if (Model.PuedeEditar)
            {
                <button class="btn" type="button">Editar</button>
            }

            @if (Model.PuedeConsultar)
            {
                <button class="btn" type="button">Consultar</button>
            }

            @if (Model.PuedeEliminar)
            {
                <button class="btn" type="button">Eliminar</button>
            }

            @if (Model.PuedeDetalle)
            {
                <button class="btn" type="button">Detalle</button>
            }
        </div>

        @if (!Model.PuedeAgregar && !Model.PuedeEditar && !Model.PuedeConsultar && !Model.PuedeEliminar && !Model.PuedeDetalle)
        {
            <div class="alert alert-info">
                No tienes acciones disponibles para este módulo.
            </div>
        }
    </div>
</div>
